### 경기 생성
POST http://localhost:8080/api/games
Content-Type: application/json

{
  "stadiumId": 1,
  "homeTeamId": 1,
  "awayTeamId": 2,
  "sportType": "BASEBALL",
  "startAt": "2025-07-01T18:00:00",
  "durationMinutes": 180,
  "status": "ON_SALE",
  "dayType": "WEEKDAY",
  "gameGrade": "NORMAL",
  "maxTicketPerUser": 4,
  "saleStartAt": "2025-06-01T10:00:00",
  "saleEndAt": "2025-07-01T12:00:00"
}

> {%
  client.test("2xx/3xx", function() { client.assert(response.status >= 200 && response.status < 400, "status: " + response.status); });
%}
